{
  "name": "mepo-playwright-automation",
  "version": "1.0.0",
  "description": "Playwright automation tests for dev.mepo.travel",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:demo": "npx playwright test --headed --workers=1 --project=chromium",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "test:debug": "npx playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
